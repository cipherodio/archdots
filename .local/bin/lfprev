#!/bin/sh
# Author: cipherodio
# Description: Wrapper for lf with ueberzugpp image previews.

cleanup() {
    # close fd safely
    exec 3>&- 2>/dev/null || true

    # kill ueberzug if still alive
    [ -n "$UEBERZUG_PID" ] && kill "$UEBERZUG_PID" 2>/dev/null || true

    # remove fifo safely
    [ -p "$FIFO_UEBERZUG" ] && rm -f "$FIFO_UEBERZUG" 2>/dev/null || true
}

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    exec lf "$@"
fi

mkdir -p "$HOME/.cache/lf"

FIFO_UEBERZUG="$HOME/.cache/lf/ueberzug-$$"
export FIFO_UEBERZUG

mkfifo "$FIFO_UEBERZUG"

ueberzug layer -s -p json <"$FIFO_UEBERZUG" &
UEBERZUG_PID=$!

exec 3>"$FIFO_UEBERZUG"

trap cleanup HUP INT QUIT TERM EXIT

lf "$@" 3>&-
