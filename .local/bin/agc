#!/usr/bin/env bash
# Author: cipherodio
# Description: Check AwesomeWM memory, clean it, and notify via Dunst

# 1. Get initial memory (in KB)
initial_kb=$(awesome-client 'return collectgarbage("count")' | awk '{print $2}')
initial_mb=$(echo "scale=2; $initial_kb / 1024" | bc)

# 2. Run Garbage Collection twice for a deep clean
awesome-client 'collectgarbage("collect"); collectgarbage("collect")' > /dev/null

# 3. Get final memory
final_kb=$(awesome-client 'return collectgarbage("count")' | awk '{print $2}')
final_mb=$(echo "scale=2; $final_kb / 1024" | bc)

# 4. Calculate saved memory
saved_mb=$(echo "scale=2; $initial_mb - $final_mb" | bc)

# 5. Send notification to Dunst
# Use -u low so it doesn't stay on screen too long
dunstify -a "AwesomeGC" -u low -i "system-software-update" \
    "WM Memory Cleaned" \
    "Before: ${initial_mb}MB\nAfter: ${final_mb}MB\nCleaned: ${saved_mb}MB"
