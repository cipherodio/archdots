#!/bin/sh
# Author: cipherodio
# Description: Select MPD track via dmenu (no numbers, no tmpfile)

set -eu

list=$(mpc playlist -f "%position%\t%file%" 2>/dev/null || true)

[ -n "$list" ] || exit 0

choice=$(
    printf '%s\n' "$list" |
        cut -f2 |
        dmenu -i -l 10 -p "track"
)

[ -n "$choice" ] || exit 0

pos=$(
    printf '%s\n' "$list" |
        awk -F'\t' -v c="$choice" '$2 == c {print $1; exit}'
)

[ -n "$pos" ] || exit 0

mpc play "$pos" >/dev/null 2>&1
