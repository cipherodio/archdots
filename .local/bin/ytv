#!/bin/sh
# Author: cipherodio
# Description: Download YouTube video (best video + audio) as MP4 using yt-dlp

set -eu

url=${1:-}

if [ -z "$url" ]; then
    printf '%s\n' 'Usage: ytv <youtube-url>' >&2
    exit 1
fi

yt-dlp \
    -f 'bestvideo+bestaudio' \
    --merge-output-format mp4 \
    --restrict-filenames \
    -o "$HOME/hub/downloads/%(title)s.%(ext)s" \
    "$url"
