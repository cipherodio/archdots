#!/bin/sh
# Author: cipherodio
# Description: Toggle touchpad using xinput via dmenu

set -eu

for cmd in xinput dmenu notify-send; do
    command -v "$cmd" >/dev/null 2>&1 || {
        notify-send "padtoggle error" "$cmd not found"
        exit 1
    }
done

id=$(
    xinput list |
        sed -n 's/.*[Tt]ouchpad.*id=\([0-9][0-9]*\).*/\1/p' |
        head -n 1
)

if [ -z "$id" ]; then
    notify-send "Touchpad" "Touchpad not found"
    exit 1
fi

enabled=$(
    xinput list-props "$id" |
        awk '/Device Enabled/ { print $NF }'
)

confirm() {
    printf '%s\n' "Yes" |
        dmenu -p "$1" >/dev/null
}

if [ "$enabled" = "1" ]; then
    if confirm "[🟢 TOUCHPAD ON] Disable touchpad?"; then
        xinput disable "$id"
        notify-send "Touchpad" "OFF"
    fi
else
    if confirm "[🔴 TOUCHPAD OFF] Enable touchpad?"; then
        xinput enable "$id"
        notify-send "Touchpad" "ON"
    fi
fi
