#!/usr/bin/env bash
# Author: cipherodio
# Description: Go to previous track in Spotify via MPRIS

set -euo pipefail

dbus-send --print-reply \
    --dest=org.mpris.MediaPlayer2.spotify \
    /org/mpris/MediaPlayer2 \
    org.mpris.MediaPlayer2.Player.Previous \
    >/dev/null 2>&1

# Last Modified: Mon, 26 Jan 2026 04:55:27 PM
