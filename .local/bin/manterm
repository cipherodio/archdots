#!/bin/sh
# Author: cipherodio
# Description: Search via dmenu and open man pages in a terminal

set -eu

TERMINAL=${TERMINAL:-st}

choice=$(
    apropos . |
        awk '{ print $1 " " $2 }' |
        sort -u |
        dmenu -i -l 10 -p "manpage"
)

[ -n "$choice" ] || exit 0

name=${choice%% *}
section=${choice#*(}
section=${section%)}

"$TERMINAL" -e man "$section" "$name" &
