#!/bin/sh
# Author: cipherodio
# Description: Open bookmarked web pages via dmenu

set -eu

BROWSER=${BROWSER:-firefox}
BOOKMARKS="${XDG_DATA_HOME:-$HOME/.local/share}/misc/bookmarks"

[ -f "$BOOKMARKS" ] || exit 1

choice=$(
    cut -d'|' -f1 "$BOOKMARKS" |
        sort |
        dmenu -i -l 10 -p "website:"
)

[ -n "${choice:-}" ] || exit 0

url=$(
    awk -F'|' -v c="$choice" '$1 == c { print $2; exit }' "$BOOKMARKS"
)

[ -n "${url:-}" ] || exit 1

exec "$BROWSER" "$url"
