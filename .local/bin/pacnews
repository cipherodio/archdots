#!/usr/bin/env bash
# Author: cipherodio
# Description: Show latest Arch Linux news and optionally run system upgrade

set -euo pipefail

NEWS_FEED="https://archlinux.org/feeds/news/"
NEWS_LIMIT=10

# Colors
ESC="$(printf '\033')"
BOLD="${ESC}[1m"
BLUE="${ESC}[34m"
YELLOW="${ESC}[33m"
RED="${ESC}[31m"
RESET="${ESC}[0m"

# Check required commands
for cmd in curl sudo; do
    if ! command -v "$cmd" &>/dev/null; then
        printf '%sError: %s is not installed.%s\n' "$RED" "$cmd" "$RESET"
        exit 1
    fi
done

printf '%s%s🔔 Latest Arch Linux news:%s\n\n' "$BOLD" "$BLUE" "$RESET"

if ! news="$(
    curl -fs --max-time 10 --connect-timeout 5 "$NEWS_FEED" |
        sed -n '/<item>/,/<\/item>/ {
            s/.*<title>\(.*\)<\/title>.*/\1/p
        }' |
        sed -e 's/&gt;/>/g' -e 's/&lt;/</g' -e 's/&amp;/\&/g' -e 's/&quot;/"/g' -e "s/&apos;/'/g" |
        head -n "$NEWS_LIMIT"
)"; then
    printf '%sError: failed to fetch Arch Linux news.%s\n' "$RED" "$RESET"
    exit 1
fi

if [[ -z "$news" ]]; then
    printf '%sWarning: No news items found.%s\n' "$YELLOW" "$RESET"
fi

while IFS= read -r title; do
    case "$title" in
    *[Mm]anual\ intervention*)
        printf '%s- %s%s\n' "$RED" "$title" "$RESET"
        ;;
    *)
        printf '%s- %s%s\n' "$YELLOW" "$title" "$RESET"
        ;;
    esac
done <<<"$news"

printf '\n%sContinue with system upgrade? [y/N] %s' "$BOLD" "$RESET"
read -r -t 30 answer

if [[ -z "$answer" ]]; then
    printf '\n%s⏹️  No response - upgrade cancelled.%s\n' "$BOLD" "$RESET"
    exit 0
fi

case "$answer" in
[yY])
    # Check if pacman is already running
    if [[ -f /var/lib/pacman/db.lck ]]; then
        printf '%s%s⚠️  Pacman is already running (lock file exists).%s\n' "$BOLD" "$RED" "$RESET"
        exit 1
    fi

    printf '%s%s⏫ Running pacman -Syu...%s\n' "$BOLD" "$RED" "$RESET"
    exec sudo pacman -Syu
    ;;
*)
    printf '%s⏹️  Upgrade cancelled.%s\n' "$BOLD" "$RESET"
    exit 0
    ;;
esac
