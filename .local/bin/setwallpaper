#!/usr/bin/env bash
# Author: cipherodio
# Description: Set wallpaper using feh

set -euo pipefail

BGDIR="${XDG_DATA_HOME:-$HOME/.local/share}"
BGFILE="$BGDIR/bg"

mkdir -p "$BGDIR"

if [ -f "${1:-}" ]; then
    cp -f "$1" "$BGFILE"

    setsid -f notify-send -i "$BGFILE" \
        " Wallpaper changed" >/dev/null 2>&1
fi

[ -f "$BGFILE" ] || exit 0

setsid -f feh --no-fehbg --bg-fill "$BGFILE" >/dev/null 2>&1
