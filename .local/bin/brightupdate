#!/usr/bin/env bash
# Author: cipherodio
# Description: Change brightness and sync with AwesomeWM

set -euo pipefail

delta=${1:-"+5%"}
msg_id=991050

# Apply brightness change
brightnessctl set "$delta" >/dev/null

# Get new percentage for notification
current_perc=$(brightnessctl -m | cut -d, -f4 | tr -d '%')

# Notify (Dunst)
dunstify \
    -a "brightnessbar" \
    -u low \
    -r "$msg_id" \
    -h "int:value:$current_perc" \
    "Brightness: ${current_perc}%"

# Trigger the refresh in AwesomeWM
awesome-client 'awesome.emit_signal("brightness_refresh")'
