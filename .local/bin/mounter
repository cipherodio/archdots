#!/bin/bash
# Mount: USB drives + Android phones via dmenu
# Mounts to ~/.local/mnt/<device>

IFS=$'\n'
MNT="$HOME/.local/mnt"
mkdir -p "$MNT"

USER_UID="$(id -u)"
USER_GID="$(id -g)"

# Android phones
phones="$(simple-mtpfs -l 2>/dev/null | sed 's/^/📱 /')"

# USB Drives (unmounted partitions only)
usbparts="$(
    lsblk -nrpo NAME,TYPE,MOUNTPOINT |
        awk '$2=="part" && $3=="" { printf "💾 %s\n", $1 }'
)"

# Menu
choices="$(printf "%s\n%s\n" "$phones" "$usbparts" | sed '/^$/d')"

if [ -z "$choices" ]; then
    notify-send "mounter" "No mountable devices found"
    exit 0
fi

chosen="$(echo "$choices" | dmenu -i -p 'Mount which device?')"
[ -n "$chosen" ] || exit 0

# Action
case "$chosen" in
💾*)
    dev="${chosen#💾 }"
    name="$(basename "$dev")"
    mp="$MNT/$name"

    fstype="$(lsblk -no FSTYPE "$dev")"
    mkdir -p "$mp"

    case "$fstype" in
    vfat | exfat | fat | ntfs)
        sudo -A mount "$dev" "$mp" \
            -o uid="$USER_UID",gid="$USER_GID",rw,umask=0022
        ;;
    ext4 | btrfs | xfs)
        sudo -A mount "$dev" "$mp"
        sudo chown "$USER_UID:$USER_GID" "$mp"
        ;;
    *)
        sudo -A mount "$dev" "$mp"
        ;;
    esac

    notify-send "💾 Drive mounted" "$dev → $mp"
    ;;

📱*)
    notify-send "📱 Android" "Allow file access on your phone"

    num="${chosen#📱 }"
    num="${num%%:*}"
    mp="$MNT/android-$num"
    mkdir -p "$mp"

    sudo simple-mtpfs \
        -o allow_other \
        --device "$num" "$mp"

    notify-send "📱 Android mounted" "$mp"
    ;;
esac

