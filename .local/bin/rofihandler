#!/usr/bin/env bash
# Author: cipherodio
# Description: Handle URL via rofi
# Used in: newsboat

set -euo pipefail

exec 2>/dev/null

url=${1-}
[[ -n $url ]] || exit 0

choices=(
    copy
    browser
    mpv
    download
    ytv
    yta
    nsxiv
)

program=$(
    printf '%s\n' "${choices[@]}" |
        rofi -dmenu -p 'Open with'
)

[[ -n ${program-} ]] || exit 0

case $program in
copy)
    printf '%s' "$url" | xclip -selection clipboard >/dev/null 2>&1
    ;;

browser)
    setsid -f "${BROWSER:-firefox}" "$url" >/dev/null 2>&1
    ;;

mpv)
    setsid -f mpv -quiet --profile=M60 "$url" >/dev/null 2>&1
    ;;

download)
    notify-send "Download" "started"
    {
        cd "$HOME/hub/downloads"
        if curl -sLO "$url"; then
            notify-send "Download" "finished: ${url##*/}"
        else
            notify-send "Download" "FAILED"
        fi
    } >/dev/null 2>&1 &
    disown
    ;;

ytv)
    notify-send "YouTube Video" "Download started"
    {
        if yt-dlp --batch-file /dev/null \
            -f 'bestvideo+bestaudio' \
            --merge-output-format mp4 \
            --restrict-filenames \
            -o "$HOME/hub/downloads/%(title)s.%(ext)s" \
            "$url"; then
            notify-send "YouTube Video" "Download finished"
        else
            notify-send "YouTube Video" "Download FAILED (Check /tmp/ytdl-error.log)"
        fi
    } </dev/null >/tmp/ytdl-error.log 2>&1 &
    disown
    ;;

yta)
    notify-send "YouTube Audio" "Download started"
    {
        if yt-dlp --batch-file /dev/null \
            -x \
            --audio-format mp3 \
            --audio-quality 0 \
            --restrict-filenames \
            -o "$HOME/hub/downloads/%(title)s.%(ext)s" \
            "$url"; then
            notify-send "YouTube Audio" "Download finished"
        else
            notify-send "YouTube Audio" "Download FAILED (Check /tmp/ytdl-error.log)"
        fi
    } </dev/null >/tmp/ytdl-error.log 2>&1 &
    disown
    ;;

nsxiv)
    notify-send "Image" "opening..."
    {
        file=${url##*/}
        tmp="/tmp/$file"
        if curl -sL "$url" >"$tmp"; then
            nsxiv -ab "$tmp"
        else
            notify-send "Image" "Download FAILED"
        fi
    } >/dev/null 2>&1 &
    disown
    ;;
esac
