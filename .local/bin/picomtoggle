#!/bin/sh
# Toggle picom on/off with dmenu confirmation

confirm() {
    printf "Yes" | dmenu -i -p "$1" >/dev/null
}

if pgrep -x picom >/dev/null; then
    confirm "[● ON] Turn OFF picom?" && {
        notify-send "Picom" "OFF"
        pkill picom
    }
else
    confirm "[○ OFF] Turn ON picom?" && {
        picom -b
        notify-send "Picom" "ON"
    }
fi

