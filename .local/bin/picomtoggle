#!/bin/sh
# Author: cipherodio
# Description: Toggle picom compositor via dmenu

set -eu

for cmd in dmenu notify-send pgrep pkill picom; do
    command -v "$cmd" >/dev/null 2>&1 || {
        notify-send "picomtoggle error" "$cmd not found"
        exit 1
    }
done

confirm() {
    printf '%s\n' "Yes" | dmenu -p "$1"
}

if pgrep -x picom >/dev/null 2>&1; then
    if confirm "[🟢 ON] Turn OFF picom?"; then
        pkill -x picom
        notify-send "Picom" "OFF"
    fi
else
    if confirm "[🔴 OFF] Turn ON picom?"; then
        picom -b
        notify-send "Picom" "ON"
    fi
fi
