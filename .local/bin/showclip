#!/bin/sh
# Author: cipherodio
# Description: Display contents of clipboard and primary selection

set -eu

clip="$(xclip -o -selection clipboard 2>/dev/null || true)"
prim="$(xclip -o -selection primary 2>/dev/null || true)"

menu="$(printf "clipboard\nprimary\n" | dmenu -i -p "Select:")"

case "$menu" in
clipboard)
    [ -n "$clip" ] && printf '%s\n' "$clip" | dmenu -p "Clipboard"
    ;;
primary)
    [ -n "$prim" ] && printf '%s\n' "$prim" | dmenu -p "Primary"
    ;;
esac
