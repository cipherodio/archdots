#!/bin/sh
# Author: cipherodio
# Description: Update mirrorlist

set -eu

COUNTRY="Singapore,Hong Kong"
MIRRORLIST="/etc/pacman.d/mirrorlist"

sudo -v

sudo cp "$MIRRORLIST" "${MIRRORLIST}.backup.$(date +%Y%m%d%H%M%S)"

sudo reflector \
    --country "$COUNTRY" \
    --protocol https \
    --latest 15 \
    --sort rate \
    --save "$MIRRORLIST"

printf 'Mirrorlist updated.\n'
