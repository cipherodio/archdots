#!/usr/bin/env bash
# Author: cipherodio
# Description: Update mirrorlist

set -euo pipefail

COUNTRY="Singapore,Hong Kong"
MIRRORLIST="/etc/pacman.d/mirrorlist"

sudo -v

sudo cp "$MIRRORLIST" "${MIRRORLIST}.backup.$(date +%Y%m%d%H%M%S)"

sudo reflector \
    --country "$COUNTRY" \
    --protocol https \
    --latest 15 \
    --sort rate \
    --save "$MIRRORLIST"

echo "Mirrorlist updated."
