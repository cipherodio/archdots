#!/bin/sh
# Author: cipherodio
# Description: Toggle Emacs daemon on/off with confirmation

set -eu

confirm() {
    printf '%s\n' "Yes" | dmenu -p "$1" >/dev/null
}

is_emacs_daemon_running() {
    emacsclient -e '(daemonp)' 2>/dev/null | grep -q t
}

if is_emacs_daemon_running; then
    if confirm '[🟢 ON] Stop Emacs daemon?'; then
        emacsclient -e '(kill-emacs)' >/dev/null 2>&1 || true
        notify-send "Emacs" "Daemon stopped"
    fi
else
    if confirm '[🔴 OFF] Start Emacs daemon?'; then
        emacs --daemon >/dev/null 2>&1 &
        notify-send "Emacs" "Daemon started"
    fi
fi
