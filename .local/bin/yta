#!/bin/sh
# Author: cipherodio
# Description: Download YouTube audio as MP3 using yt-dlp

set -eu

url=${1:-}

if [ -z "$url" ]; then
    printf '%s\n' 'Usage: yta <youtube-url>' >&2
    exit 1
fi

yt-dlp \
    -x \
    --audio-format mp3 \
    --audio-quality 0 \
    --restrict-filenames \
    -o "$HOME/hub/downloads/%(title)s.%(ext)s" \
    "$url"
