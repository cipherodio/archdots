#!/bin/sh
# Author: cipherodio
# Description: Show currently playing song from MPD via dunst

set -eu

MSG_ID="280307"

sleep 0.15

status=$(mpc status 2>/dev/null)

# Only notify if actually playing
printf '%s\n' "$status" | grep -q '\[playing\]' || exit 0

song=$(mpc current 2>/dev/null)
[ -n "$song" ] || exit 0

dunstify \
    -a "mpcnotify" \
    -u low \
    -r "$MSG_ID" \
    "Now Playing" "$song"
