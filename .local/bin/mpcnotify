#!/usr/bin/env bash
# Author: cipherodio
# Description: Show currently playing song from MPD via dunst

set -euo pipefail

MSG_ID="280307"

# Small delay to avoid race from mpcplaylist script
sleep 0.15

status="$(mpc status)"

# Only notify if actually playing
grep -q '\[playing\]' <<<"$status" || exit 0

song="$(mpc current)"
[ -n "$song" ] || exit 0

dunstify \
    -a "mpcnotify" \
    -u low \
    -r "$MSG_ID" \
    "Now Playing" "$song"
