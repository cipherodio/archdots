#!/bin/sh
# Toggle unclutter on/off with dmenu confirmation

confirm() {
    printf "Yes" | dmenu -i -p "$1" >/dev/null
}

if pgrep -x unclutter >/dev/null; then
    confirm "[● ON] Turn OFF unclutter?" &&
        pkill unclutter &&
        notify-send "Unclutter" "OFF"
else
    confirm "[○ OFF] Turn ON unclutter?" && {
        unclutter --timeout 3 -jitter 50 --ignore-scrolling &
        notify-send "Unclutter" "ON"
    }
fi

