#!/bin/sh
# Author: cipherodio
# Description: Fast emoji selection via dmenu

set -eu

EMOJI_FILE="$HOME/.local/share/misc/emoji"

chosen=$(
    cat "$EMOJI_FILE" |
        dmenu -i -l 10 -p "emoji"
)

[ -z "$chosen" ] && exit 0

emoji=${chosen%% *}

printf '%s' "$emoji" | xclip -selection clipboard
notify-send "Emoji" "$emoji copied"
