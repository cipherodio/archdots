#!/usr/bin/env bash

case $BLOCK_BUTTON in
1)
    notify-send "🧠 Memory hogs" "$(ps axch -o cmd,%mem | awk '{cmd[$1]+=$2} END {for (i in cmd) print i, cmd[i]}' | sort -nrk2 | head)"
    ;;
2)
    notify-send "🧠 Memory module" -- "- Left: show memory hogs.\n- Right: htop."
    ;;
3) setsid -f "$TERMINAL" -e htop ;;
esac

# Extract total and used memory
read -r total used <<<"$(free --mebi | awk '/^Mem:/ {print $2, $3}')"

# Safety check for empty variables
if [[ -z "$total" || "$total" -eq 0 ]]; then
    printf "🧠?%%\n"
    exit 1
fi

# Calculate percentage
perc=$((100 * used / total))

# Removed space between icon and value
printf "🧠%d%%\n" "$perc"
printf "%d%%\n" "$perc"
