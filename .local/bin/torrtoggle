#!/bin/sh
# Transmission-daemon toggle with Yes confirmation

confirm() {
    printf "Yes" | dmenu -i -p "$1" >/dev/null
}

if pidof transmission-daemon >/dev/null; then
    confirm "[● ON] Turn OFF transmission-daemon?" &&
        killall transmission-daemon &&
        notify-send "Transmission" "Daemon stopped"
else
    ifinstalled transmission-daemon
    confirm "[○ OFF] Turn ON transmission-daemon?" &&
        transmission-daemon >/dev/null 2>&1 &&
        notify-send "Transmission" "Daemon started"
fi

