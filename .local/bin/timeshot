#!/bin/sh

timer=$(printf '%s\n' 1 5 10 | dmenu -p 'Seconds to wait') || exit 1

output="$HOME/.local/screenshot/$(date '+%G-%d-%b-%I:%M%p').png"

sleep "$timer"

maim -q "$output"
xclip -selection clipboard -t image/png "$output"

notify-send "📸 Screenshot taken"

