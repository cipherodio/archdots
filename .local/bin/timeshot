#!/bin/sh
# Take screenshot with timer

timer=$(printf '%s\n' 0.5 5 10 | dmenu -p 'Seconds to wait') || exit

output="$HOME/.local/screenshot/$(date '+%G-%d-%b-%I:%M%p').png"

sleep "$timer"

maim -q - | tee "$output" | xclip -selection clipboard -t image/png
notify-send "📸 Screenshot taken."

