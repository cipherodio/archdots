#!/bin/sh
# Author: cipherodio
# Description: Timed screenshot with dmenu selector

set -eu

timer="$(
    printf "%s\n" "1" "5" "10" |
        dmenu -i -p "Seconds to wait"
)" || exit 1

[ -n "$timer" ] || exit 1

output="$HOME/hub/screenshot/$(date '+%Y-%d-%b-%I:%M%p').png"

sleep "$timer"

maim -q "$output"
xclip -selection clipboard -t image/png <"$output"

notify-send "📸 Screenshot taken"
