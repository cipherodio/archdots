#!/usr/bin/env bash
# Author: cipherodio
# Description: Reset Neovim state

set -euo pipefail

ROFI_STYLE='window { width: 210px; } listview { lines: 2; }'

confirm() {
    printf 'Yes\n' | rofi -dmenu -i -p "$1" -theme-str "$ROFI_STYLE" >/dev/null
}

if confirm "Reset Neovim state?"; then
    rm -rf \
        "$HOME/.config/nvim/lazy-lock.json" \
        "$HOME/.local/share/nvim" \
        "$HOME/.local/state/nvim" \
        "$HOME/.cache/nvim"

    notify-send "Neovim" "State reset complete"
fi
