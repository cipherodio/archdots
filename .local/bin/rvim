#!/bin/sh
# Author: cipherodio
# Description: Reset Neovim state

set -eu

confirm() {
    printf '%s\n' "Yes" |
        dmenu -p "$1" >/dev/null
}

if confirm "Reset Neovim state?"; then
    rm -rf \
        "$HOME/.config/nvim/nvim-pack-lock.json" \
        "$HOME/.local/share/nvim" \
        "$HOME/.local/state/nvim" \
        "$HOME/.cache/nvim"

    notify-send "Neovim" "State reset complete"
fi
