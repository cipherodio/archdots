#!/usr/bin/env bash
# Author: cipherodio
# Description: Volume

case $BLOCK_BUTTON in
1)
    setsid -w -f "$TERMINAL" -e pulsemixer
    pkill -RTMIN+10 "${STATUSBAR:-i3blocks}"
    ;;
2)
    notify-send "📢 Volume module" -- "- Left: mixer\n- Scroll: vol\n- Right: mute"
    ;;
3)
    pulsemixer --toggle-mute
    ;;
4)
    pulsemixer --change-volume +5
    ;;
5)
    pulsemixer --change-volume -5
    ;;
esac

# Handle mute
if [[ "$(pulsemixer --get-mute)" == "1" ]]; then
    printf "🔇\n"
    exit
fi

# Get volume
vol_val=$(pulsemixer --get-volume | awk '{print $1}')

# Determine icon
if ((vol_val >= 70)); then
    icon="🔊"
elif ((vol_val >= 30)); then
    icon="🔉"
elif ((vol_val >= 1)); then
    icon="🔈"
else
    printf "🔇\n"
    exit
fi

printf "%s%d%%\n" "$icon" "$vol_val"
