#!/bin/sh
# Author: cipherodio
# Description: Memory status for dwmblocks

notif_hog=$(
    ps axch -o cmd,%mem |
        awk '
            {cmd[$1]+=$2}
            END {
                for (i in cmd)
                    print i, cmd[i]
            }' |
        sort -nrk2 |
        head
)

notif_guide="🧠 Memory module
- Left click: memory hogs
- Right click: htop"

case "$BLOCK_BUTTON" in
1) notify-send "🧠 Memory hogs" "$notif_hog" ;;
2) notify-send "$notif_guide" ;;
3) setsid -f "$TERMINAL" -e htop ;;
esac

awk '
/MemTotal:/ {t=$2}
/MemAvailable:/ {a=$2}
END {
    if (t > 0 && a >= 0)
        printf "🧠%d%%\n", (t-a)*100/t
}
' /proc/meminfo
