#!/bin/sh
# Author: cipherodio
# Description: Download YouTube video as MP4 using yt-dlp

set -eu

YTDLP=/usr/bin/yt-dlp
OUTDIR=$HOME/hub/downloads

url=${1:-}

if [ -z "$url" ]; then
    notify-send --urgency critical "ď…¦ Youtube download" "No URL provided"
    exit 1
fi

notify-send --urgency low "ď…¦ Youtube download" "Started\n$url"

if "$YTDLP" \
    --force-generic-extractor \
    -f 'bestvideo+bestaudio/best' \
    --merge-output-format mp4 \
    --restrict-filenames \
    -o "$OUTDIR/%(title)s.%(ext)s" \
    "$url" >/dev/null 2>&1; then
    notify-send --urgency normal "ď…¦ Youtube download" "Finished\n$url"
else
    notify-send --urgency critical "ď…¦ Youtube download" "Failed\n$url"
fi
