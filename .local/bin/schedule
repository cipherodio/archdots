#!/bin/sh
# Author: cipherodio
# Description: Show calendar with today highlighted & print agenda via less

set -eu

AGENDA_FILE="$HOME/hub/src/mdnotes/agenda.md"

today=$(date +%e | tr -d ' ')

GREEN=$(printf '\033[1;32m')
RESET=$(printf '\033[0m')

{
    cal | awk -v today="$today" -v green="$GREEN" -v reset="$RESET" '
    NR <= 2 { print; next }
    {
        for (i = 1; i <= NF; i++) {
            if ($i == today)
                $i = green $i reset
        }
        print
    }'

    printf '\n'

    if [ -f "$AGENDA_FILE" ]; then
        highlight --out-format=ansi "$AGENDA_FILE"
    else
        printf '%sAgenda file not found:%s %s\n' \
            "$GREEN" "$RESET" "$AGENDA_FILE"
    fi
} | less -R
