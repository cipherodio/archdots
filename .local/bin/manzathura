#!/bin/sh
# Search man pages via dmenu and open as PDF in zathura

choice=$(
    apropos . |
        awk '{ print $1 " " $2 }' |
        sort -u |
        dmenu -i -l 10 -p man
) || exit 0

[ -z "$choice" ] && exit 0

# Extract name and section
name=$(printf '%s\n' "$choice" | awk '{print $1}')
section=$(printf '%s\n' "$choice" | sed -n 's/.*(\(.*\)).*/\1/p')

# IMPORTANT: -Tpdf must come BEFORE section/name
man -Tpdf "$section" "$name" 2>/dev/null | zathura - &

