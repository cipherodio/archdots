#!/bin/sh
# Author: cipherodio
# Description: Search man pages via dmenu and open them as PDF in zathura

set -eu

choice=$(
    apropos . |
        awk '{ print $1 " " $2 }' |
        sort -u |
        dmenu -i -l 10 -p "manpage"
)

[ -n "$choice" ] || exit 0

name=${choice%% *}
section=${choice#* }
section=$(printf '%s' "$section" | tr -d '()')

man -Tpdf "$section" "$name" 2>/dev/null | zathura -
