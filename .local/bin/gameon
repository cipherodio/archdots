#!/bin/sh
# Author: cipherodio
# Description: Toggle game mode (disable/enable picom and unclutter)

set -eu

confirm() {
    printf '%s\n' "Yes" | dmenu -p "$1" >/dev/null
}

picom_running() {
    pgrep -x picom >/dev/null 2>&1
}

unclutter_running() {
    pgrep -x unclutter >/dev/null 2>&1
}

if picom_running || unclutter_running; then
    if confirm "[🔴 GAME MODE] Disable picom & unclutter?"; then
        pkill -x picom 2>/dev/null || true
        pkill -x unclutter 2>/dev/null || true
        notify-send "Game Mode" "ON"
    fi
else
    if confirm "[🟢 NORMAL MODE] Enable picom & unclutter?"; then
        unclutter --timeout 3 -jitter 50 --ignore-scrolling >/dev/null 2>&1 &
        picom -b >/dev/null 2>&1 &
        notify-send "Game Mode" "OFF"
    fi
fi
