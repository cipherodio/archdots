#!/bin/sh
# Author: cipherodio
# Description: Battery status for dwmblocks

notif_guide="🔋 Battery module
🔋: discharging
🟠: not charging
♻: stagnant charge
🔌: charging
⚡: charged
❗: battery very low!"

case "$BLOCK_BUTTON" in
2) notify-send "$notif_guide" ;;
esac

output=""

# Loop through batteries
for battery in /sys/class/power_supply/BAT?*; do
    [ -e "$battery" ] || continue

    # Separator
    if [ -n "$output" ]; then
        output="$output "
    fi

    # Read status and capacity
    read -r raw_status <"$battery/status"
    read -r capacity <"$battery/capacity"

    case "$raw_status" in
    Full) status="⚡" ;;
    Discharging) status="🔋" ;;
    Charging) status="🔌" ;;
    "Not charging") status="🟠" ;;
    Unknown) status="♻️" ;;
    *) status="?" ;;
    esac

    # Low battery warning
    warn=""
    if [ "$status" = "🔋" ] && [ "$capacity" -le 25 ] 2>/dev/null; then
        warn="❗"
    fi

    output="${output}${status}${warn}${capacity}%"
done

printf "%s\n" "$output"
