#!/bin/sh
# Author: cipherodio
# Description: Generate shell, zsh, and lf shortcuts from bookmark files

bmdirs="$XDG_CONFIG_HOME/shell/bm-dirs"
bmfiles="$XDG_CONFIG_HOME/shell/bm-files"

shrc="$XDG_CONFIG_HOME/shell/shrc"
zshrc="$XDG_CONFIG_HOME/shell/zshdirrc"
lf="$XDG_CONFIG_HOME/lf/shrc"

expand_path() {
    eval "printf '%s\n' \"$1\""
}

rm -f "$lf" "$zshrc"
printf '# vim: filetype=sh\nalias ' >"$shrc"

# Directories
while read -r key path _; do
    case "$key" in
    '' | \#*) continue ;;
    esac

    printf '%s="cd %s" \\\n' "$key" "$path" >>"$shrc"
    printf 'hash -d %s=%s\n' "$key" "$path" >>"$zshrc"

    lf_path=$(expand_path "$path")
    printf 'map g%s cd "%s"\n' "$key" "$lf_path" >>"$lf"
done <"$bmdirs"

# Files
while read -r key path _; do
    case "$key" in
    '' | \#*) continue ;;
    esac

    printf '%s="\044EDITOR %s" \\\n' "$key" "$path" >>"$shrc"
    printf 'hash -d %s=%s\n' "$key" "$path" >>"$zshrc"

    lf_path=$(expand_path "$path")
    printf 'map E%s \044EDITOR "%s"\n' "$key" "$lf_path" >>"$lf"
done <"$bmfiles"
