#!/bin/sh
# Author: cipherodio
# Description: Show brightness change as a dunst progress bar

set -eu

action=${1:-0}
msg_id=991050

case "$action" in
-*)
    brightnessctl set "${action#-}%-" >/dev/null
    ;;
+*)
    brightnessctl set "${action#+}%+" >/dev/null
    ;;
*)
    brightnessctl set "${action}%" >/dev/null
    ;;
esac

current_bright=$(
    brightnessctl -m |
        awk -F',' '{
        for (i=1; i<=NF; i++) {
            if ($i ~ /^[0-9.]+%$/) {
                sub("%","",$i)
                print int($i)
                exit
            }
        }
    }'
)

[ -n "${current_bright:-}" ] || current_bright=0

dunstify -a "brightbar" -u low -r "$msg_id" \
    -h "int:value:$current_bright" \
    "Brightness: ${current_bright}%"
