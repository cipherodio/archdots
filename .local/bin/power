#!/bin/sh
# Power menu via dmenu

confirm() {
    printf "Yes" | dmenu -i -p "$1" >/dev/null
}

opts="’Ćæ  Poweroff
¾░Ŗ│  Restart
¾▒æÜ  Suspend
’ü£  Logout"

choice=$(printf '%s\n' "$opts" | dmenu -i -p "Bye $USER!") || exit 0

case "$choice" in
"’Ćæ  Poweroff")
    confirm "Power off?" && systemctl poweroff -i
    ;;
"¾░Ŗ│  Restart")
    confirm "Restart?" && systemctl reboot -i
    ;;
"¾▒æÜ  Suspend")
    confirm "Suspend?" && systemctl suspend -i
    ;;
"’ü£  Logout")
    confirm "Logout?" && pkill -KILL -u "$USER"
    ;;
esac

