#!/bin/sh
# Author: cipherodio
# Description: Power menu via dmenu

set -eu

for cmd in dmenu systemctl notify-send loginctl; do
    command -v "$cmd" >/dev/null 2>&1 || {
        notify-send "power error" "$cmd not found"
        exit 1
    }
done

confirm() {
    printf 'Yes\n' |
        dmenu -p "$1" >/dev/null
}

choice=$(
    printf '%s\n' \
        '🔌  Poweroff' \
        '🔄  Restart' \
        '💤  Suspend' \
        '🚪  Logout' |
        dmenu -i -l 4 -p "Bye ${USER:-user}!"
)

[ -n "$choice" ] || exit 0

case "$choice" in
'🔌  Poweroff')
    confirm "Power off?" &&
        systemctl poweroff
    ;;
'🔄  Restart')
    confirm "Restart?" &&
        systemctl reboot
    ;;
'💤 Suspend')
    confirm "Suspend?" &&
        systemctl suspend
    ;;
'🚪  Logout')
    confirm "Logout?" &&
        loginctl terminate-user "$USER"
    ;;
esac
