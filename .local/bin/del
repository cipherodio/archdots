#!/bin/sh
# Author: cipherodio
# Description: Move a file to trash

set -eu

td="$HOME/.local/trash"
mkdir -p "$td"

# If no args, exit
[ $# -gt 0 ] || exit 0

for f in "$@"; do
    case "$f" in
    --)
        continue
        ;;
    -*)
        # treat as invalid file, pass to rm fallback
        printf "Skipping invalid option: %s\n" "$f" >&2
        continue
        ;;
    *)
        mv --backup=t -v "$f" "$td"
        ;;
    esac
done
