#!/bin/sh
# Author: cipherodio
# Description: Battery remaining time notification

set -eu

command -v acpi >/dev/null 2>&1 || {
    dunstify "Battery" "acpi not installed"
    exit 1
}

info=$(acpi -b | head -n 1)

percent=$(printf '%s\n' "$info" | cut -d',' -f2 | sed 's/^ //')
time=$(printf '%s\n' "$info" | cut -d',' -f3 | sed 's/^ //')

[ -n "$time" ] || time="No estimate"

dunstify "Battery" "$percent · $time"
