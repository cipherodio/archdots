#!/usr/bin/env bash
# Author: cipherodio
# Description: Battery remaining time notification

set -euo pipefail

if ! command -v acpi >/dev/null 2>&1; then
    dunstify "Battery" "acpi not installed"
    exit 1
fi

info="$(acpi -b | head -n1)"

percent="$(awk -F', ' '{print $2}' <<<"$info")"
time="$(awk -F', ' '{print $3}' <<<"$info")"

if [[ -z "${time:-}" ]]; then
    time="No estimate"
fi

dunstify "Battery" "$percent · $time"
