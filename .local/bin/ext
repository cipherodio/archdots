#!/bin/sh
# Author: cipherodio
# Description: General-purpose archive extraction script

set -eu

extract_here=false

usage() {
    printf "Options:\n"
    printf "  -c  Extract into current directory (default: new directory)\n"
    exit 1
}

while getopts "hc" opt; do
    case "$opt" in
    c) extract_here=true ;;
    h | *) usage ;;
    esac
done

shift $((OPTIND - 1))

[ $# -eq 1 ] || {
    printf "Give archive to extract as argument.\n"
    exit 1
}

archive=$1

[ -f "$archive" ] || {
    printf "File '%s' not found.\n" "$archive"
    exit 1
}

# Absolute path
case "$archive" in
/*) archive_path=$archive ;;
*) archive_path=$(pwd)/$archive ;;
esac

if ! $extract_here; then
    base=$(basename "$archive")
    dir=${base%.*}
    mkdir -p "$dir" || exit 1
    cd "$dir" || exit 1
fi

case "$archive" in
*.tar.bz2 | *.tbz2) tar xvjf "$archive_path" ;;
*.tar.xz) tar -xJf "$archive_path" ;;
*.tar.gz | *.tgz) tar xvzf "$archive_path" ;;
*.tar) tar xvf "$archive_path" ;;
*.bz2) bunzip2 "$archive_path" ;;
*.gz) gunzip "$archive_path" ;;
*.xz) unxz "$archive_path" ;;
*.lzma) unlzma "$archive_path" ;;
*.rar) unrar x -ad "$archive_path" ;;
*.zip) unzip "$archive_path" ;;
*.Z) uncompress "$archive_path" ;;
*.7z) 7z x "$archive_path" ;;
*.exe) cabextract "$archive_path" ;;
*)
    printf "extract: '%s' - unknown archive method\n" "$archive"
    exit 1
    ;;
esac
