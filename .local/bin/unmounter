#!/bin/bash
# dmenu-unmount: USB drives + Android phones
# Matches ~/.local/mnt mount scheme

set -e
IFS=$'\n'

MNT="$HOME/.local/mnt"

###############################################################################
# ANDROID PHONES
###############################################################################

mounteddroids="$(mount | grep simple-mtpfs | awk '{print "📱 " $3}')"

###############################################################################
# USB DRIVES
###############################################################################

mountedusb="$(lsblk -nrpo mountpoint,size |
    awk -v m="$MNT" '
        $1 ~ "^"m"/" {
            printf "💾 %s (%s)\n",$1,$2
        }
    ')"

###############################################################################
# MENU
###############################################################################

choices="$(printf "%s\n%s\n" "$mounteddroids" "$mountedusb" | sed '/^$/d')"
[ -n "$choices" ]

chosen="$(echo "$choices" | dmenu -i -p 'Unmount which device?')"
[ -n "$chosen" ]

###############################################################################
# PARSE MOUNTPOINT (FIX)
###############################################################################

mp="$chosen"
mp="${mp#📱 }"
mp="${mp#💾 }"
mp="${mp%% (*}"

###############################################################################
# UNMOUNT + CLEANUP
###############################################################################

sudo -A umount -l "$mp"
rmdir "$mp" 2>/dev/null || true

notify-send "Device unmounted" "$mp"

# Last Modified: Sat, 10 Jan 2026 05:53:38 AM
