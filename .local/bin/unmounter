#!/bin/bash
# Unmount: USB drives + Android phones via dmenu
# Unmount devices in ~/.local/mnt/<device>

set -e
IFS=$'\n'

MNT="$HOME/.local/mnt"

# Android phones
mounteddroids="$(mount | grep simple-mtpfs | awk '{print "📱 " $3}')"

# USB Drives
mountedusb="$(lsblk -nrpo mountpoint,size |
    awk -v m="$MNT" '
        $1 ~ "^"m"/" {
            printf "💾 %s (%s)\n",$1,$2
        }
    ')"

# Menu
choices="$(printf "%s\n%s\n" "$mounteddroids" "$mountedusb" | sed '/^$/d')"
[ -n "$choices" ]

chosen="$(echo "$choices" | dmenu -i -p 'Unmount which device?')"
[ -n "$chosen" ]

# Parse mountpoint
mp="$chosen"
mp="${mp#📱 }"
mp="${mp#💾 }"
mp="${mp%% (*}"

# Unmount + cleanup
sudo -A umount -l "$mp"
rmdir "$mp" 2>/dev/null || true

notify-send "Device unmounted" "$mp"

