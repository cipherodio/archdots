#!/bin/sh
# Author: cipherodio
# Description: Unmount USB drives and Android phones using dmenu
# Dependencies: simple-mtpfs
# Unmounts devices in ~/.local/mnt

set -eu

MNT="$HOME/.local/mnt"

# Android devices
mounteddroids=$(
    mount 2>/dev/null |
        awk '/simple-mtpfs/ { print "📱 " $3 }' || true
)

# USB mounts under ~/.local/mnt
mountedusb=$(
    lsblk -nrpo MOUNTPOINT,SIZE 2>/dev/null |
        awk -v m="$MNT" '
        $1 ~ "^" m "/" {
            printf "💾 %s (%s)\n", $1, $2
        }
    ' || true
)

choices=$(printf "%s\n%s\n" "$mounteddroids" "$mountedusb" | sed '/^$/d')

[ -n "$choices" ] || {
    notify-send "unmounter" "No mounted devices found"
    exit 0
}

chosen=$(
    printf "%s\n" "$choices" |
        dmenu -i -p "Unmount which device?"
)

[ -n "$chosen" ] || exit 0

# Extract mountpoint
mp=$chosen
mp=${mp#📱 }
mp=${mp#💾 }
mp=${mp%% (*}

sudo -A umount -l "$mp"

rmdir "$mp" 2>/dev/null || true

notify-send "Device unmounted" "$mp"
