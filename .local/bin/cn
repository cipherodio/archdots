#!/bin/sh
# Author: cipherodio
# Description: Personal notes CLI with flag-based commands
# Usage: cn [options]
# -i quick notes
# -j journal for current date
# -v vault note
# -p create new prose
# -ii fzf inbox directory
# -jj fzf journal directory
# -vv fzf vault directory
# -pp fzf prose directory

set -eu

# Colors
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    BOLD=$(printf '\033[1m')
    GREEN=$(printf '\033[32m')
    CYAN=$(printf '\033[36m')
    BLUE=$(printf '\033[34m')
    RESET=$(printf '\033[0m')
else
    BOLD="" GREEN="" CYAN="" BLUE="" RESET=""
fi

# Directories
BASE_DIR="$HOME/hub/src/mdnotes"
JOURNAL_DIR="$BASE_DIR/journal"
PROSE_DIR="$BASE_DIR/prose"
VAULT_DIR="$BASE_DIR/vault"
INBOX_DIR="$BASE_DIR/inbox"

EDITOR="${EDITOR:-nvim}"

META_DATE_FMT="%B %d, %Y %a %I:%M %p"
FILE_DATE_FMT="%b-%d-%Y-%a"

current_date=$(date +"$META_DATE_FMT")

# Usage
usage() {
    printf "%scn%s is a simple notes CLI.\n" "$BOLD" "$RESET"
    printf "author: cipherodio\n\n"

    printf "%sUsage:%s %scn%s %s[options]%s\n\n" \
        "$BOLD" "$RESET" "$BOLD$GREEN" "$RESET" "$BOLD$BLUE" "$RESET"

    printf "%sCommands:%s\n" "$BOLD" "$RESET"
    printf "  %s-j%s   Today's journal\n" "$CYAN" "$RESET"
    printf "  %s-p%s   Create new prose\n" "$CYAN" "$RESET"
    printf "  %s-v%s   Vault note\n" "$CYAN" "$RESET"
    printf "  %s-i%s   Inbox note\n" "$CYAN" "$RESET"
    printf "  %s-jj%s  Browse journal\n" "$CYAN" "$RESET"
    printf "  %s-pp%s  Browse prose\n" "$CYAN" "$RESET"
    printf "  %s-vv%s  Browse vault\n" "$CYAN" "$RESET"
    printf "  %s-ii%s  Browse inbox\n" "$CYAN" "$RESET"

    exit 0
}

# Prompt
prompt() {
    label=$1

    printf "%s%s:%s " "${BOLD}${CYAN}" "$label" "$RESET" >/dev/tty || return 1
    IFS= read -r value </dev/tty || return 1

    printf '%s\n' "$value"
}

# Helper
slugify() {
    printf "%s\n" "$1" |
        tr '[:upper:]' '[:lower:]' |
        sed 's/[^a-z0-9]/_/g; s/^_*//; s/_*$//'
}

open_editor() {
    exec "$EDITOR" "$1"
}

pick_and_open() {
    dir=$1

    file=$(
        find "$dir" -maxdepth 1 -type f 2>/dev/null |
            sed "s|$BASE_DIR/||" |
            fzf
    )

    [ -n "${file:-}" ] || return 0
    open_editor "$BASE_DIR/$file"
}

# Mode
mode=${1:-}

[ -n "$mode" ] || usage

case "$mode" in
-j)
    title="Journal"
    author="Jeremy"

    file_date=$(date +"$FILE_DATE_FMT" | tr '[:upper:]' '[:lower:]')
    file_date=$(printf "%s" "$file_date" | sed 's/thu/thurs/')
    filepath="$JOURNAL_DIR/$file_date.md"

    if [ ! -e "$filepath" ]; then
        cat >"$filepath" <<EOF
---
title: $title
author: $author
created: "$current_date"
---
EOF
    fi

    open_editor "$filepath"
    ;;

-p)
    title=$(prompt "Title")
    author=$(prompt "Author")
    description=$(prompt "Description")
    filename_input=$(prompt "Filename (leave blank to use title)")

    slug=$(slugify "${filename_input:-$title}")
    filepath="$PROSE_DIR/$slug.md"

    if [ ! -e "$filepath" ]; then
        cat >"$filepath" <<EOF
---
title: $title
author:${author:+ $author}
created: "$current_date"
completed: ""
uploaded: ""
description:${description:+ $description}
---
EOF
    fi

    open_editor "$filepath"
    ;;

-v)
    title=$(prompt "Title")
    author=$(prompt "Author")
    description=$(prompt "Description")
    filename_input=$(prompt "Filename (leave blank to use title)")

    slug=$(slugify "${filename_input:-$title}")
    filepath="$VAULT_DIR/$slug.md"

    if [ ! -e "$filepath" ]; then
        cat >"$filepath" <<EOF
---
title: $title
author:${author:+ $author}
created: "$current_date"
description:${description:+ $description}
---
EOF
    fi

    open_editor "$filepath"
    ;;

-i)
    title=$(prompt "Title")
    author=$(prompt "Author")
    description=$(prompt "Description")
    filename_input=$(prompt "Filename (leave blank to use title)")

    slug=$(slugify "${filename_input:-$title}")
    filepath="$INBOX_DIR/$slug.md"

    if [ ! -e "$filepath" ]; then
        cat >"$filepath" <<EOF
---
title: $title
author:${author:+ $author}
created: $current_date
description:${description:+ $description}
---
EOF
    fi

    open_editor "$filepath"
    ;;

-jj) pick_and_open "$JOURNAL_DIR" ;;
-pp) pick_and_open "$PROSE_DIR" ;;
-vv) pick_and_open "$VAULT_DIR" ;;
-ii) pick_and_open "$INBOX_DIR" ;;

*) usage ;;
esac
