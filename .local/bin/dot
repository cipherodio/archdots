#!/bin/sh
# Author: cipherodio
# Description: Wrapper for bare-repo dotfiles management

set -eu

DOTS="$HOME/.config/.dots"
WORKTREE="$HOME"

dotfiles() {
    git --git-dir="$DOTS" --work-tree="$WORKTREE" "$@"
}

cmd=${1-}

LICENSE="$HOME/LICENSE"
README="$HOME/README.md"

case "$cmd" in
out)
    dotfiles pull

    [ -e "$LICENSE" ] && dotfiles update-index --assume-unchanged "$LICENSE"
    [ -e "$README" ] && dotfiles update-index --assume-unchanged "$README"

    rm -f "$LICENSE" "$README"
    ;;

in)
    [ -e "$LICENSE" ] && dotfiles update-index --no-assume-unchanged "$LICENSE"
    [ -e "$README" ] && dotfiles update-index --no-assume-unchanged "$README"

    dotfiles checkout -f
    ;;

"")
    dotfiles st
    ;;

*)
    dotfiles "$@"
    ;;
esac
