#!/usr/bin/env bash
# Author: cipherodio
# Description: Pacman wrapper for common operations

set -euo pipefail

# Colors
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    BOLD=$(printf '\033[1m')
    GREEN=$(printf '\033[32m')
    CYAN=$(printf '\033[36m')
    BLUE=$(printf '\033[34m')
    RESET=$(printf '\033[0m')
else
    BOLD="" GREEN="" CYAN="" BLUE="" RESET=""
fi

usage() {
    printf "%spm%s is a simple pacman wrapper.\n" "$BOLD" "$RESET"
    printf "author: cipherodio\n\n"

    printf "%sUsage:%s %s%s%s %s%s%s\n\n" \
        "$BOLD" "$RESET" \
        "$BOLD$GREEN" "pm" "$RESET" \
        "$BOLD$BLUE" "[options]" "$RESET"

    printf "%sCommands:%s\n" "$BOLD" "$RESET"
    printf "  %su%s          System upgrade\n" "$CYAN" "$RESET"
    printf "  %si%s <pkg>    Install package(s)\n" "$CYAN" "$RESET"
    printf "  %sr%s <pkg>    Remove package(s)\n" "$CYAN" "$RESET"
    printf "  %sc%s          Clean cache\n" "$CYAN" "$RESET"
    printf "  %ss%s <pkg>    Search packages\n" "$CYAN" "$RESET"
    printf "  %sq%s <pkg>    Query installed package\n" "$CYAN" "$RESET"
}

# If no args, show help
if [[ $# -eq 0 ]]; then
    usage
    exit 0
fi

cmd="$1"
shift

case "$cmd" in
i) exec sudo pacman -S "$@" ;;
u) exec sudo pacman -Syu ;;
r) exec sudo pacman -Rns "$@" ;;
c) exec sudo pacman -Sc ;;
s) exec pacman -Ss "$@" ;;
q) exec pacman -Qi "$@" ;;
*)
    exec sudo pacman "$cmd" "$@"
    ;;
esac
