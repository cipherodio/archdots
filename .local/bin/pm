#!/bin/sh
# Package manager wrapper (pacman)

pm_pacman() {
    cmd="$1"
    shift

    case "$cmd" in
    i) sudo pacman -S "$@" ;;   # Sync packages
    u) sudo pacman -Syu "$@" ;; # Sync and update packages
    r) sudo pacman -Rns "$@" ;; # Uninstall package including dependencies
    c) sudo pacman -Sc ;;       # Remove packages that are no longer installed
    s) pacman -Ss "$@" ;;       # Search for a packages
    q) pacman -Qi "$@" ;;       # Query package database and display information
    *) sudo pacman "$cmd" "$@" ;;
    esac
}

command -v pacman >/dev/null 2>&1 || {
    echo "pacman not found"
    exit 1
}

pm_pacman "$@"

