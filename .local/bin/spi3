#!/usr/bin/env bash
# Author: cipherodio
# # Description: Scratchpad for i3wm

APP="$1"

if [ -z "$APP" ]; then
    exit 1
fi

CLASS="scratchpad_$APP"

if i3-msg -t get_tree | grep -q "\"$CLASS\""; then
    i3-msg "[class=\"$CLASS\"] scratchpad show"
else
    alacritty \
        --class "$CLASS","$CLASS" \
        -e "$APP" &

    # wait until i3 sees the window
    while ! i3-msg -t get_tree | grep -q "\"$CLASS\""; do
        sleep 0.05
    done

    # let resize/floating rules finish first
    sleep 0.20

    i3-msg "[class=\"$CLASS\"] scratchpad show"
fi
