#!/bin/sh
# Author: cipherodio
# Description: Print all 256 ANSI colours with readable contrast

COLOURS=256

contrast_colour() {
    cc_c=$1

    if [ "$cc_c" -lt 16 ]; then
        if [ "$cc_c" -eq 0 ]; then
            printf '15'
        else
            printf '0'
        fi
        return
    fi

    if [ "$cc_c" -gt 231 ]; then
        if [ "$cc_c" -lt 244 ]; then
            printf '15'
        else
            printf '0'
        fi
        return
    fi

    cc_g=$((((cc_c - 16) % 36) / 6))

    if [ "$cc_g" -gt 2 ]; then
        printf '0'
    else
        printf '15'
    fi
}

print_colour() {
    pc_c=$1
    pc_fg=$(contrast_colour "$pc_c")

    printf '\033[48;5;%sm\033[38;5;%sm%3d\033[0m ' \
        "$pc_c" "$pc_fg" "$pc_c"
}

print_run() {
    pr_start=$1
    pr_count=$2

    pr_i=$pr_start
    pr_end=$((pr_start + pr_count))

    while [ "$pr_i" -lt "$pr_end" ] && [ "$pr_i" -lt "$COLOURS" ]; do
        print_colour "$pr_i"
        pr_i=$((pr_i + 1))
    done

    printf '  '
}

print_blocks() {
    pb_start=$1
    pb_end=$2
    pb_cols=$3
    pb_rows=$4
    pb_per_line=$5

    pb_block_len=$((pb_cols * pb_rows))
    pb_i=$pb_start

    while [ "$pb_i" -le "$pb_end" ]; do
        printf '\n'

        pb_row=0
        while [ "$pb_row" -lt "$pb_rows" ]; do

            pb_block=0
            while [ "$pb_block" -lt "$pb_per_line" ]; do
                print_run \
                    $((pb_i + pb_block * pb_block_len + pb_row * pb_cols)) \
                    "$pb_cols"

                pb_block=$((pb_block + 1))
            done

            printf '\n'
            pb_row=$((pb_row + 1))
        done

        pb_i=$((pb_i + pb_block_len * pb_per_line))
    done
}

print_run 0 16
printf '\n'

print_blocks 16 231 6 6 3
print_blocks 232 255 12 2 1
