#!/bin/sh
# Author: cipherodio
# Description: Backup files to external drive

set -eu

MOUNT_BASE="$HOME/.local/mnt/sda1"

DIRS="
$HOME/.local/share/calcurse|$MOUNT_BASE/home/calcurse
$HOME/.local/share/task|$MOUNT_BASE/home/task
$HOME/hub/src/cipherkeys|$MOUNT_BASE/home/cipherkeys
"

# Safety check
if [ ! -d "$MOUNT_BASE" ]; then
    printf 'ERROR: backup drive not mounted at %s\n' "$MOUNT_BASE"
    exit 1
fi

# Iterate mappings
printf '%s\n' "$DIRS" | while IFS='|' read -r SRC DEST; do
    [ -n "$SRC" ] || continue

    printf 'Syncing:\n'
    printf '  %s → %s\n' "$SRC" "$DEST"

    if [ ! -d "$SRC" ]; then
        printf 'Skipping missing source: %s\n' "$SRC"
        continue
    fi

    mkdir -p "$DEST"

    rsync -a --delete -- "$SRC/" "$DEST/"

    printf 'Done.\n\n'
done

# Refresh lf if running
if command -v lf >/dev/null 2>&1 && pgrep -x lf >/dev/null 2>&1; then
    lf -remote "send reload" >/dev/null 2>&1 || true
fi

printf 'All backups completed successfully.\n'
