include themes/cipherodio.theme

news.version=3.4.2
verbose=0
allow.delete=yes
allow.purge=yes
# confirmation=1
#recurrence.limit=1
hooks.location=~/.config/task/hooks

# NOTE: Below for upcoming merge for 12hr support
#dateformat=Y-M-D a I:N p
dateformat=M/D/y a H:N
weekstart=monday

report.list.columns=id,scheduled.relative,due.relative,description,scheduled,due
report.list.labels=ID,ETS,ETD,DESCRIPTION,SCHEDULE,DEADLINE

report.next.columns=id,project,priority,urgency,description,due.relative,scheduled.relative
report.next.labels=ID,PROJECT,P,URGENCY,DESCRIPTION,ETD,ETS

report.scheduled.filter=status:pending and scheduled.any:
report.scheduled.columns=id,project,scheduled.relative,description,scheduled
report.scheduled.labels=ID,PROJECT,ETS,DESCRIPTION,SCHEDULE

report.due.filter=status:pending and due.any:
report.due.columns=id,project,due.relative,description,due
report.due.labels=ID,PROJECT,ETD,DESCRIPTION,DEADLINE

# report.deleted.description=Deleted tasks

# report.deleted.labels=ID,Status,Due,Description,Date & Time
# report.deleted.columns=id,status,due.relative,description,due
# report.deleted.filter=status:deleted

## EXP

uda.taskwarrior-tui.selection.indicator=›
#uda.taskwarrior-tui.selection.bold=yes
#uda.taskwarrior-tui.selection.italic=no
#uda.taskwarrior-tui.selection.dim=no
#uda.taskwarrior-tui.selection.blink=no
uda.taskwarrior-tui.selection.reverse=no
uda.taskwarrior-tui.task-report.use-alternate-style=false
uda.taskwarrior-tui.task-report.show-info=false

uda.taskwarrior-tui.style.report.selection=black on cyan
uda.taskwarrior-tui.style.navbar=black on blue
uda.taskwarrior-tui.style.command=black on blue

