# General
show-read-feeds yes
auto-reload no
confirm-mark-all-feeds-read no
confirm-mark-feed-read no
max-items 50
reload-threads 8
show-read-feeds yes
show-read-articles yes
error-log "~/.config/newsboat/error.log"
goto-first-unread no
goto-next-feed no

# Bindings
bind-key j down
bind-key k up
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key G end
bind-key g home
bind-key d pagedown
bind-key u pageup
bind-key l open
bind-key h quit
bind-key a toggle-article-read
bind-key n next-unread
bind-key N prev-unread
bind-key D pb-download
bind-key U show-urls
bind-key x pb-delete

# Formats
feedlist-format "%t %u"
articlelist-format "%4i %f %D %?T?|%-17T| ?%t"
feedlist-title-format "%N feeds with new articles(%u/%t) "
articlelist-title-format "%T"

# Feed list
highlight feedlist "(Distro News|Youtube|Subreddits)" red black bold
highlight feedlist "(Webtoon|Tech News)" red black bold

# Colors
color listnormal color244 default
color listnormal_unread white default
color listfocus red default
color listfocus_unread red default bold
color info blue default bold
color article white default bold

highlight all "---.*---" yellow
highlight feedlist ".*(0/0))" black green bold
highlight article "(^Feed:.*|^Title:.*|^Author:.*)" cyan default bold
highlight article "(^Link:.*|^Date:.*)" default default underline
highlight article "https?://[^ ]+" green default
highlight article "\\[[0-9][0-9]*\\]" magenta default bold
highlight article "\\[image [0-9][0-9]*\\]" green default bold
highlight article "\\[embedded flash: [0-9][0-9]*\\]" green default bold
highlight article ":.*\\(link\\)$" cyan default
highlight article ":.*\\(image\\)$" blue default
highlight article ":.*\\(embedded flash\\)$" magenta default

# Macros
bind-key ` macro-prefix
unbind-key ,
browser linkhandler

# Options: macro+d or `+d
# copy: copy link
# browser: open in $BROWSER
# mpv: open in mpv
# download: attachments
# ytv: download videos
# yta: download audio only
macro d set browser "setsid -f rofihandler %u"; open-in-browser; set browser linkhandler
# Copy link to clipboard
macro c set browser "setsid -f sh -c 'printf %s %u | xclip -r -sel c && notify-send \"󱓦 URL copied to clipboard\"'"; open-in-browser; set browser linkhandler
# Open in $BROWSER
macro b set browser "setsid -f $BROWSER"; open-in-browser; set browser linkhandler
