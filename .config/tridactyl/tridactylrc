" vim: filetype=vim
" Delete all settings except what's here
sanitize tridactyllocal tridactylsync

" Manage screen space
guiset_quiet hoverlink right

" General Settings
"set modeindicatormodes {"ignore":"false"}
"set modeindicatorshowkeys true
set modeindicator false
set smoothscroll true
" set hintfiltermode vimperator
set findresults -1
set hintfiltermode simple
set hintshift false
set hintnames uniform
set tabsort mru

set hintstyles.bg none
set hintstyles.fg none
set hintstyles.outline none

" Bindings
unbind d
unbind <C-f>
bind dd tabclose
bind u undo
bind <C-h> tabmove -1
bind <C-l> tabmove +1
bind = zoom 0.1 true
bind - zoom -0.1 true
bind 0 zoom 1.0
bind p clipboard open
bind P clipboard tabopen
bind <A-m> mute toggle
bind qq qall

" Watch or download video and audio via yt-dlp current page
bind ,v composite js tri.native.run("setsid -f /home/cipherodio/.local/bin/ytdlvideo " + document.location.href) | exclaim_quiet true
bind ,a composite js tri.native.run("setsid -f /home/cipherodio/.local/bin/ytdlaudio " + document.location.href) | exclaim_quiet true
bind ,m composite js tri.native.run("setsid -f mpv --quiet --profile=M60 " + document.location.href) | exclaim_quiet true

" Watch or download video and audio via yt-dlp hinted links
bind ,V hint -W exclaim_quiet setsid -f /home/cipherodio/.local/bin/ytdlvideo
bind ,A hint -W exclaim_quiet setsid -f /home/cipherodio/.local/bin/ytdlaudio
bind ,M hint -W exclaim_quiet setsid -f mpv --quiet --profile=M60
