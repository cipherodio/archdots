#!/bin/sh
# File preview handler for lf.

set -C -f
IFS="$(printf '%b_' '\n')"
IFS="${IFS%_}"

image() {
    if command -v ueberzugpp >/dev/null 2>&1; then
        UB="ueberzugpp"
    else
        UB="ueberzug"
    fi

    if [ -f "$1" ] &&
        [ -n "$DISPLAY" ] &&
        [ -z "$WAYLAND_DISPLAY" ] &&
        command -v "$UB" >/dev/null 2>&1; then

        printf '{"action": "add", "identifier": "PREVIEW", "x": "%s", "y": "%s", "width": "%s", "height": "%s", "scaler": "contain", "path": "%s"}\n' \
            "$4" "$5" "$(($2 - 1))" "$(($3 - 1))" "$1" \
            2>/dev/null >"$FIFO_UEBERZUG" || true

    else
        mediainfo "$6"
    fi
}

get_cache() {
    printf '%s' "${XDG_CACHE_HOME:-$HOME/.cache}/lf/thumb.$(
        stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f "$1")" |
            sha256sum |
            awk '{print $1}'
    )"
}

# --- Fast path: highlight by extension ---
case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
*.md | *.markdown | *.txt | *.py | *.toml | *.sh | *.zsh | *.bash | *.lua | \
    *.json | *.js | *.css | *.html | *rc | *config | *.conf | *profile | \
    *.cpp | *.h | *.rs | *.go | *.java | *.yaml | *.yml | *dockerfile*)
    highlight --out-format=ansi \
        --width "$(($4 - 2))" \
        --force "$1" |
        head -n 200
    exit 0
    ;;
esac

case "$(file --dereference --brief --mime-type -- "$1")" in

image/avif)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.jpg" ] && magick "$1" "$CACHE.jpg"
    image "$CACHE.jpg" "$2" "$3" "$4" "$5" "$1"
    ;;

image/vnd.djvu)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.jpg" ] &&
        djvused "$1" -e 'select 1; save-page-with /dev/stdout' |
        magick -density 200 - "$CACHE.jpg" >/dev/null 2>&1
    image "$CACHE.jpg" "$2" "$3" "$4" "$5" "$1"
    ;;

image/svg+xml)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.png" ] &&
        inkscape --convert-dpi-method=none \
            -o "$CACHE.png" \
            --export-overwrite \
            -D \
            --export-png-color-mode=RGBA_16 \
            "$1"
    image "$CACHE.png" "$2" "$3" "$4" "$5" "$1"
    ;;

image/x-xcf)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.jpg" ] &&
        magick "$1" "$CACHE.jpg"
    image "$CACHE.jpg" "$2" "$3" "$4" "$5" "$1"
    ;;

image/*)
    image "$1" "$2" "$3" "$4" "$5" "$1"
    ;;

text/html)
    lynx -width="$4" -display_charset=utf-8 -dump "$1"
    ;;

text/troff)
    man ./ "$1" | col -b
    ;;

text/* | */xml | application/json | application/x-ndjson | application/javascript)
    highlight --out-format=ansi \
        --width "$(($4 - 2))" \
        --force "$1" |
        head -n 200
    ;;

audio/* | application/octet-stream)
    mediainfo "$1" || exit 1
    ;;

video/*)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE" ] &&
        ffmpegthumbnailer -i "$1" -o "$CACHE" -s 0
    image "$CACHE" "$2" "$3" "$4" "$5" "$1"
    ;;

*/pdf)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.jpg" ] &&
        pdftoppm -jpeg -f 1 -singlefile "$1" "$CACHE"
    image "$CACHE.jpg" "$2" "$3" "$4" "$5" "$1"
    ;;

*/epub+zip | */mobi*)
    CACHE=$(get_cache "$1")
    [ ! -f "$CACHE.jpg" ] &&
        gnome-epub-thumbnailer "$1" "$CACHE.jpg"
    image "$CACHE.jpg" "$2" "$3" "$4" "$5" "$1"
    ;;

application/*zip | application/x-tar | application/x-7z-compressed)
    atool --list -- "$1"
    ;;

*opendocument*)
    odt2txt "$1"
    ;;

application/pgp-encrypted)
    gpg -d -- "$1"
    ;;

esac

exit 1
